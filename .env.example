# ===========================================
# AI 简历助手 — 环境变量清单
# ===========================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env
# ===========================================

# ===========================================
# LLM 配置（后端使用）
# ===========================================
# 支持: openai, anthropic, gemini, openrouter, deepseek, ollama, openai_compatible
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=
# 可选：自定义 API 地址（Ollama / 本地模型必填）
# LLM_API_BASE=

# 推理深度（部分模型支持）: minimal | low | medium | high
# REASONING_EFFORT=

# ===========================================
# 服务器配置（后端）
# ===========================================
HOST=
PORT=
# 开发模式热重载: true | false
# RELOAD=

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=
LOG_LLM=

# ===========================================
# 前端地址（后端跨域 & PDF 生成用）
# ===========================================
FRONTEND_BASE_URL=
# CORS 允许的来源（JSON 数组）
CORS_ORIGINS=

# ===========================================
# 前端配置（Next.js）
# ===========================================
# 后端 API 地址，默认 "/" 走 Next.js 代理
# NEXT_PUBLIC_API_URL=

# ===========================================
# 数据库（Neon PostgreSQL）
# ===========================================
# DATABASE_URL=

# ===========================================
# Better Auth（前端认证）
# ===========================================
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=
# BACKEND_ORIGIN=
